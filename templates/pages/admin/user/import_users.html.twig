{% extends "layout/page_without_tabs.html.twig" %}

{% import 'components/form/fields_macros.html.twig' as fields %}

{% set container_size = "xl" %}

{% block content_title %}
    {{ __('Import users from spreadsheet') }}
{% endblock content_title %}

{% block content_body %}
    <div class="row g-3">
        <div class="col-12 col-xl-8">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                        <div>
                            <h2 class="card-title mb-1">{{ __('Upload spreadsheet') }}</h2>
                            <p class="text-secondary mb-0">
                                {{ __('Only users who can create users manually can access this page.') }}
                            </p>
                        </div>
                        <a class="btn btn-outline-secondary" href="{{ path('front/user.import.php') }}?download_template=1">
                            <i class="ti ti-download"></i>
                            <span>{{ __('Download template') }}</span>
                        </a>
                    </div>

                    <div class="alert alert-info" role="alert">
                        {{ __('Supported formats: %s')|format(supported_extensions|join(', ')|upper) }}<br>
                        {{ __('Use preview first to validate mappings before writing into GLPI.') }}<br>
                        {{ __('Passwords for existing users are ignored unless "Update passwords" is enabled.') }}
                    </div>

                    {% if global_error %}
                        <div class="alert alert-danger" role="alert">
                            {{ global_error }}
                        </div>
                    {% endif %}

                    <form method="POST" enctype="multipart/form-data" action="{{ path('front/user.import.php') }}" data-submit-once>
                        {{ fields.fileField(
                            'import_file',
                            '',
                            __('Spreadsheet'),
                            {
                                is_horizontal: true,
                                simple: true,
                                required: true,
                                accept: '.xlsx,.xls,.csv'
                            }
                        ) }}
                        {{ fields.textField('sheet', form.sheet, __('Sheet name'), {
                            helper: __('Leave empty to use the active sheet.')
                        }) }}
                        {{ fields.dropdownArrayField('mode', form.mode, mode_options, __('Mode'), {
                            display_emptychoice: false
                        }) }}
                        {{ fields.dropdownArrayField('default_profile', form.default_profile, default_profile_options, __('Default profile'), {
                            display_emptychoice: false
                        }) }}
                        {{ fields.dropdownArrayField('default_entity', form.default_entity, default_entity_options, __('Default entity'), {
                            display_emptychoice: false
                        }) }}
                        {{ fields.dropdownArrayField('default_location', form.default_location, default_location_options, __('Default location'), {
                            display_emptychoice: false
                        }) }}
                        {{ fields.textField('default_language', form.default_language, __('Default language')) }}
                        {{ fields.dropdownArrayField('default_active', form.default_active, default_active_options, __('Default active state'), {
                            display_emptychoice: false
                        }) }}
                        {{ fields.checkboxField('update_passwords', form.update_passwords, __('Update passwords')) }}

                        <div class="d-flex justify-content-end gap-2 mt-3">
                            <button class="btn btn-outline-primary" type="submit" name="run_mode" value="dry-run">
                                <i class="ti ti-eye"></i>
                                <span>{{ __('Preview import') }}</span>
                            </button>
                            <button class="btn btn-primary" type="submit" name="run_mode" value="execute">
                                <i class="ti ti-upload"></i>
                                <span>{{ __('Import users') }}</span>
                            </button>
                        </div>

                        <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}" />
                    </form>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-4">
            <div class="card mb-3">
                <div class="card-body">
                    <h2 class="card-title">{{ __('Expected columns') }}</h2>
                    <div class="d-flex flex-wrap gap-2">
                        {% for column in supported_columns %}
                            <span class="badge bg-secondary-lt">{{ column }}</span>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-body">
                    <h2 class="card-title">{{ __('Profiles') }}</h2>
                    <ul class="list-group list-group-flush">
                        {% for id, name in references.profiles %}
                            <li class="list-group-item px-0 d-flex justify-content-between">
                                <span>{{ name }}</span>
                                <span class="text-secondary">{{ id }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-body">
                    <h2 class="card-title">{{ __('Entities') }}</h2>
                    <ul class="list-group list-group-flush">
                        {% for id, name in references.entities %}
                            <li class="list-group-item px-0 d-flex justify-content-between">
                                <span>{{ name }}</span>
                                <span class="text-secondary">{{ id }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <h2 class="card-title">{{ __('Locations') }}</h2>
                    <ul class="list-group list-group-flush">
                        {% for id, name in references.locations %}
                            <li class="list-group-item px-0 d-flex justify-content-between">
                                <span>{{ name }}</span>
                                <span class="text-secondary">{{ id }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
        </div>
    </div>

    {% if import_result %}
        {% set is_dry_run = import_result.options.dry_run %}
        <div class="card mt-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                    <div>
                        <h2 class="card-title mb-1">{{ is_dry_run ? __('Preview results') : __('Import results') }}</h2>
                        <p class="text-secondary mb-0">
                            {{ is_dry_run ? __('No changes were written to GLPI.') : __('The selected spreadsheet has been applied.') }}
                        </p>
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    {% for key, value in import_result.stats %}
                        <div class="col-6 col-xl-3">
                            <div class="card bg-body-tertiary border-0">
                                <div class="card-body py-3">
                                    <div class="text-secondary text-uppercase small">{{ key }}</div>
                                    <div class="fs-2 fw-bold">{{ value }}</div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>

                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>{{ __('Row') }}</th>
                                <th>{{ __('Login') }}</th>
                                <th>{{ __('Status') }}</th>
                                <th>{{ __('Message') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in import_result.rows %}
                                {% set badge_class = 'bg-secondary-lt text-secondary' %}
                                {% if row.status == 'created' %}
                                    {% set badge_class = 'bg-green-lt text-green' %}
                                {% elseif row.status == 'updated' %}
                                    {% set badge_class = 'bg-blue-lt text-blue' %}
                                {% elseif row.status == 'skipped' %}
                                    {% set badge_class = 'bg-yellow-lt text-yellow' %}
                                {% elseif row.status == 'errors' %}
                                    {% set badge_class = 'bg-red-lt text-red' %}
                                {% endif %}
                                <tr>
                                    <td>{{ row.row }}</td>
                                    <td>{{ row.login ?: '—' }}</td>
                                    <td><span class="badge {{ badge_class }}">{{ row.status }}</span></td>
                                    <td>{{ row.message }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    {% endif %}
{% endblock content_body %}
